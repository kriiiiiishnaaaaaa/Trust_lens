# ─────────────────────────────────────────────
# TrustLens — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///trustlens.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/trustlens

# MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/trustlens

# ── ML Model ──
# Path to fine-tuned checkpoint (leave default to use ImageNet pre-trained)
MODEL_PATH=checkpoints/best_model.pth

# ── Server ──
PORT=5000
FLASK_DEBUG=false

# ── Logging ──
DB_ECHO=false

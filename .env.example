# ─────────────────────────────────────────────
# TrustLens — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Groq AI (required for deepfake detection) ──
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Database ──
# SQLite (default, no setup needed):
DATABASE_URL=sqlite:///trustlens.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/trustlens

# MySQL:
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/trustlens

# ── Server ──
PORT=5000
FLASK_DEBUG=false

# ── Logging ──
DB_ECHO=false
